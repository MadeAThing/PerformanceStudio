<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:models="clr-namespace:PlanViewer.Core.Models;assembly=PlanViewer.Core"
        x:Class="PlanViewer.App.Dialogs.ManageConnectionsDialog"
        Title="Manage Connections"
        Width="640" Height="480"
        MinWidth="560" MinHeight="360"
        WindowStartupLocation="CenterOwner"
        Icon="avares://PlanViewer.App/EDD.ico"
        Background="{DynamicResource BackgroundBrush}">

    <Grid Margin="20" RowDefinitions="Auto,*,Auto">
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
            <Button Content="New Connection" Click="New_Click"
                    Height="32" Padding="12,0" FontSize="13"
                    Theme="{StaticResource AppButton}"/>
        </StackPanel>

        <ScrollViewer Grid.Row="1">
            <ListBox x:Name="ConnectionsList" Background="Transparent" BorderThickness="0">
                <ListBox.ItemTemplate>
                    <DataTemplate x:DataType="models:ServerConnection">
                        <Grid ColumnDefinitions="Auto,*,Auto,Auto,Auto,Auto" Margin="0,6">
                            <ToggleButton Grid.Column="0" Content="★" Tag="{Binding}"
                                          IsChecked="{Binding IsFavorite, Mode=OneWay}"
                                          Click="Favorite_Click" Width="32" Height="32"
                                          Padding="0" VerticalAlignment="Center"/>

                            <StackPanel Grid.Column="1" Margin="8,0" VerticalAlignment="Center">
                                <TextBlock Text="{Binding DisplayName}"
                                           Foreground="{DynamicResource ForegroundBrush}"
                                           FontSize="13" FontWeight="Bold"/>
                                <TextBlock Text="{Binding AuthenticationDisplay}"
                                           Foreground="{DynamicResource ForegroundBrush}"
                                           FontSize="11" Opacity="0.7"/>
                            </StackPanel>

                            <TextBlock Grid.Column="2" Text="{Binding LastConnected, StringFormat='{}{0:yyyy-MM-dd HH:mm}'}"
                                       Foreground="{DynamicResource ForegroundBrush}"
                                       FontSize="11" Opacity="0.7"
                                       VerticalAlignment="Center" Margin="0,0,12,0"/>

                            <Button Grid.Column="3" Content="Edit" Tag="{Binding}" Click="Edit_Click"
                                    Height="28" Padding="10,0" FontSize="12" Margin="0,0,4,0"
                                    Theme="{StaticResource AppButton}"/>
                            <Button Grid.Column="4" Content="Duplicate" Tag="{Binding}" Click="Duplicate_Click"
                                    Height="28" Padding="10,0" FontSize="12" Margin="0,0,4,0"
                                    Theme="{StaticResource AppButton}"/>
                            <Button Grid.Column="5" Content="Delete" Tag="{Binding}" Click="Delete_Click"
                                    Height="28" Padding="10,0" FontSize="12"
                                    Theme="{StaticResource AppButton}"/>
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </ScrollViewer>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Close" Click="Close_Click"
                    Height="32" Padding="20,0" FontSize="13"
                    Theme="{StaticResource AppButton}"/>
        </StackPanel>
    </Grid>
</Window>
