<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:models="clr-namespace:PlanViewer.Core.Models;assembly=PlanViewer.Core"
        x:Class="PlanViewer.App.Dialogs.ConnectionDialog"
        Title="Connect to Server"
        Width="920" Height="580"
        MinWidth="800" MinHeight="480"
        WindowStartupLocation="CenterOwner"
        CanResize="True"
        Icon="avares://PlanViewer.App/EDD.ico"
        Background="{DynamicResource BackgroundBrush}">

    <Grid Margin="20" ColumnDefinitions="280,20,*">

        <!-- Saved connections list -->
        <Grid Grid.Column="0" RowDefinitions="Auto,*">
            <Button Grid.Row="0" Content="New Connection" Click="New_Click"
                    HorizontalAlignment="Stretch" Height="32" FontSize="12"
                    Margin="0,0,0,10"
                    Theme="{StaticResource AppButton}"/>

            <ScrollViewer Grid.Row="1">
                <ListBox x:Name="ConnectionsList" Background="Transparent" BorderThickness="0"
                         SelectionChanged="ConnectionsList_SelectionChanged">
                    <ListBox.ItemTemplate>
                        <DataTemplate x:DataType="models:ServerConnection">
                            <StackPanel Margin="0,0,0,10">
                                <Grid ColumnDefinitions="Auto,*">
                                    <ToggleButton Grid.Column="0" Content="★" Tag="{Binding}"
                                                  IsChecked="{Binding IsFavorite, Mode=OneWay}"
                                                  Click="Favorite_Click" Width="26" Height="26"
                                                  Padding="0" VerticalAlignment="Top"/>
                                    <TextBlock Grid.Column="1" Text="{Binding DisplayName}"
                                               Foreground="{DynamicResource ForegroundBrush}"
                                               FontSize="12" FontWeight="Bold" TextWrapping="Wrap"
                                               Margin="6,3,0,0"/>
                                </Grid>
                                <TextBlock Text="{Binding AuthenticationDisplay}"
                                           Foreground="{DynamicResource ForegroundBrush}"
                                           FontSize="10" Opacity="0.7" Margin="32,2,0,0"/>
                                <StackPanel Orientation="Horizontal" Margin="32,4,0,0" Spacing="4">
                                    <Button Content="Rename" Tag="{Binding}" Click="Rename_Click"
                                            FontSize="10" Padding="6,2" Theme="{StaticResource AppButton}"/>
                                    <Button Content="Duplicate" Tag="{Binding}" Click="Duplicate_Click"
                                            FontSize="10" Padding="6,2" Theme="{StaticResource AppButton}"/>
                                    <Button Content="Delete" Tag="{Binding}" Click="Delete_Click"
                                            FontSize="10" Padding="6,2" Theme="{StaticResource AppButton}"/>
                                </StackPanel>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </ScrollViewer>
        </Grid>

        <!-- Connection detail form -->
        <Grid Grid.Column="2" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,*,Auto">
            <!-- Server Name -->
            <TextBlock Grid.Row="0" Text="Server name" Foreground="{DynamicResource ForegroundBrush}"
                       FontSize="12" Margin="0,0,0,4"/>
            <AutoCompleteBox Grid.Row="1" x:Name="ServerNameBox"
                             Watermark="e.g. sql2022 or server.database.windows.net"
                             FontSize="13" Height="32" Margin="0,0,0,12"
                             FilterMode="ContainsOrdinal"
                             SelectionChanged="ServerName_SelectionChanged"
                             TextChanged="ServerName_TextChanged"/>

            <!-- Authentication -->
            <TextBlock Grid.Row="2" Text="Authentication" Foreground="{DynamicResource ForegroundBrush}"
                       FontSize="12" Margin="0,0,0,4"/>
            <ComboBox Grid.Row="3" x:Name="AuthTypeBox" Height="32" FontSize="13"
                      Margin="0,0,0,12" HorizontalAlignment="Stretch"
                      SelectionChanged="AuthType_SelectionChanged">
                <ComboBoxItem Content="Windows Authentication" Tag="Windows"/>
                <ComboBoxItem Content="SQL Server Authentication" Tag="SqlServer"/>
                <ComboBoxItem Content="Microsoft Entra MFA" Tag="EntraMFA"/>
            </ComboBox>

            <!-- Login -->
            <StackPanel Grid.Row="4" x:Name="LoginPanel" IsVisible="False" Margin="0,0,0,12">
                <TextBlock Text="Login" Foreground="{DynamicResource ForegroundBrush}"
                           FontSize="12" Margin="0,0,0,4"/>
                <TextBox x:Name="LoginBox" FontSize="13" Height="32" Watermark="sa"/>
            </StackPanel>

            <!-- Password -->
            <StackPanel Grid.Row="5" x:Name="PasswordPanel" IsVisible="False" Margin="0,0,0,12">
                <TextBlock Text="Password" Foreground="{DynamicResource ForegroundBrush}"
                           FontSize="12" Margin="0,0,0,4"/>
                <TextBox x:Name="PasswordBox" FontSize="13" Height="32"
                         PasswordChar="&#x25CF;" Watermark="Password"/>
            </StackPanel>

            <!-- Connection Options -->
            <StackPanel Grid.Row="6" Orientation="Horizontal" Margin="0,0,0,12" Spacing="16">
                <CheckBox x:Name="TrustCertBox" Content="Trust server certificate"
                          Foreground="{DynamicResource ForegroundBrush}" FontSize="12"/>
                <ComboBox x:Name="EncryptBox" Height="28" FontSize="11" Width="140">
                    <ComboBoxItem Content="Encrypt: Mandatory" Tag="Mandatory" IsSelected="True"/>
                    <ComboBoxItem Content="Encrypt: Optional" Tag="Optional"/>
                    <ComboBoxItem Content="Encrypt: Strict" Tag="Strict"/>
                </ComboBox>
            </StackPanel>

            <!-- Test Connection + Status -->
            <StackPanel Grid.Row="7" Orientation="Horizontal" Margin="0,0,0,12" Spacing="8">
                <Button x:Name="TestButton" Content="Test Connection" Click="TestConnection_Click"
                        Height="32" Padding="12,0" FontSize="12"
                        Theme="{StaticResource AppButton}"/>
                <TextBlock x:Name="StatusText" VerticalAlignment="Center" FontSize="12"
                           Foreground="{DynamicResource ForegroundBrush}"/>
            </StackPanel>

            <!-- Database -->
            <TextBlock Grid.Row="8" Text="Database" Foreground="{DynamicResource ForegroundBrush}"
                       FontSize="12" Margin="0,0,0,4"/>
            <AutoCompleteBox Grid.Row="9" x:Name="DatabaseBox"
                             Watermark="Type a database name, or Test Connection to list them"
                             FontSize="13" Height="32" Margin="0,0,0,12"
                             FilterMode="ContainsOrdinal" MinimumPrefixLength="0"
                             TextChanged="DatabaseBox_TextChanged"/>

            <!-- Spacer -->
            <Panel Grid.Row="10"/>

            <!-- Buttons -->
            <StackPanel Grid.Row="11" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
                <Button Content="Connect" Click="Connect_Click" x:Name="ConnectButton"
                        Height="32" Padding="20,0" FontSize="13" IsEnabled="False"
                        Theme="{StaticResource AppButton}"/>
                <Button Content="Cancel" Click="Cancel_Click"
                        Height="32" Padding="20,0" FontSize="13"
                        Theme="{StaticResource AppButton}"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
